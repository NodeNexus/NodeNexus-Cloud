# ==========================================
# VNAV Cloud Environment Configuration
# ==========================================

# Application Environment (development, staging, production)
ENVIRONMENT=production

# ==========================================
# Security Settings
# ==========================================
# Secret key used for signing JWT tokens. 
# Generate a secure key using: `openssl rand -hex 32`
JWT_SECRET_KEY=change_me_to_a_secure_random_string

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# Database Configuration
# ==========================================
# By default, VNAV Cloud uses SQLite. For production clustering, 
# you can swap this to a PostgreSQL connection string.
# Example: postgresql+asyncpg://user:password@localhost/dbname
DATABASE_URL=sqlite+aiosqlite:////app/data/vnav.db

# ==========================================
# Nginx / Proxy Settings
# ==========================================
# The domain name or IP address the frontend will be served from.
NGINX_HOST=localhost
